# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and fill in with your actual values.
# NEVER commit .env with real secrets to version control.
# Add .env to .gitignore
# ============================================================================

# ------ DATABASE ------
DB_HOST=localhost
DB_PORT=1433
DB_NAME=OnlineFruitShopping
DB_USER=sa
DB_PASSWORD=your_secure_db_password_here

# ------ GOOGLE OAUTH ------
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here_DO_NOT_EXPOSE
GOOGLE_REDIRECT_URI=http://localhost:8080/Ban_Hoa_Qua_Online/GoogleCallback

# ------ EMAIL CONFIGURATION ------
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here

# ------ SECURITY ------
SECRET_KEY=your_long_random_secret_key_min_32_chars_here
ACCESS_TOKEN_EXPIRY_MS=900000
REFRESH_TOKEN_EXPIRY_SECS=604800

# ------ APPLICATION URLS ------
APP_BASE_URL=http://localhost:8080/Ban_Hoa_Qua_Online
APP_DEPLOY_URL=https://yourdomain.com/Ban_Hoa_Qua_Online
APP_ENV=development

# ------ SEPAY / PAYMENT ------
SEPAY_BANK_ID=MB
SEPAY_ACCOUNT_NO=0394497949
SEPAY_ACCOUNT_NAME=Your Name

# ============================================================================
# PRODUCTION DEPLOYMENT INSTRUCTIONS
# ============================================================================
#
# 1. Copy this file to your production server
# 2. Update all values with production credentials
# 3. Set APP_ENV=production to enable strict validation
# 4. Ensure all required secrets are set (validation happens at startup)
# 5. Never expose .env file in web-accessible directories
# 6. Consider using a secrets management system (Vault, AWS Secrets Manager)
#
# Required secrets that MUST be set in production:
#   - GOOGLE_CLIENT_SECRET
#   - EMAIL_PASSWORD
#   - SECRET_KEY
#   - DB_PASSWORD
#
# The application will fail fast with a clear error if any required secret
# is missing when APP_ENV=production
# ============================================================================
